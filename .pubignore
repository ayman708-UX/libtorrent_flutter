# Exclude duplicate prebuilt binaries from pub.dev upload.
# iOS and macOS binaries live in ios/ and macos/ for CocoaPods.
# Windows/Linux/Android need prebuilt/ because their CMake/Gradle files reference it.
prebuilt/ios/
prebuilt/macos/

# Drop x86_64 Android ABI to stay under pub.dev's 100 MB uncompressed tar limit.
# arm64-v8a + armeabi-v7a cover all real Android devices.
# x86_64 = Intel Android emulators only (rare, can build from source).
prebuilt/android/x86_64/

# Legacy iOS static lib (replaced by xcframework)
ios/liblibtorrent_flutter.a

# CI and git files
.github/
.gitignore

# Build outputs
build/
build-*/
src/build_win/
android/.gradle/
android/build/
**/*.iml

# Example app — only include the Dart source code for pub.dev's Example tab
example/android/
example/ios/
example/linux/
example/macos/
example/windows/
example/build/
example/.dart_tool/
example/.idea/
example/integration_test/
example/pubspec.lock
example/*.iml
example/.flutter-plugins-dependencies
example/.gitignore
