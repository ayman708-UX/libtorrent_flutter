# Exclude duplicate prebuilt binaries from pub.dev upload.
# The actual platform links come from ios/, macos/, android/, windows/, linux/.
# prebuilt/ios and prebuilt/macos are exact duplicates of ios/ and macos/.
prebuilt/ios/
prebuilt/macos/

# CI and git files
.github/
.gitignore

# Build outputs
build/
build-*/

# Example app heavy platform files (keep lib/ and integration_test/)
example/android/app/src/main/res/
example/macos/Runner/Assets.xcassets/
example/windows/runner/resources/
